# ADVOKAT MCP Server – Konfiguration
# Diese Datei als .env kopieren und die Werte eintragen.
# ACHTUNG: .env niemals in git einchecken!

# Hostname oder IP-Adresse des MS SQL Servers
ADVOKAT_DB_HOST=192.168.1.XXX

# TCP-Port des SQL Servers
# Bei named instances (z.B. SERVER\ADVOKAT) den dynamischen Port
# via SQL Server Browser ermitteln (Standard UDP 1434).
# Bei Default-Instance: 1433
ADVOKAT_DB_PORT=1433

# SQL Server Login (kein Windows-Auth)
ADVOKAT_DB_USER=advokat_mcp

# Passwort des SQL Server Logins
ADVOKAT_DB_PASS=IhrPasswortHier

# Datenbankname (normalerweise nicht ändern nötig)
ADVOKAT_DB_NAME=Advokat_DATEN
